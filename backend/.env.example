# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Qdrant Cloud (required)
QDRANT_URL=https://your-cluster-id.eu-west-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=unido_evaluations

# LangSmith (optional — leave blank to disable tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=unido-ieu
LANGCHAIN_TRACING_V2=false
